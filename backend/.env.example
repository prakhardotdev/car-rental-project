# ─────────────────────────────────────────────────────────────────
# LuxeDrive Backend — .env.example
# Copy this to .env and fill in your actual values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/luxedrive?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────
# Use a long random string (min 32 chars). Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_EXPIRES_IN=7d

# ── Frontend URL (for CORS & email links) ───────────────────────
FRONTEND_URL=http://localhost:3000

# ── Cloudinary (Image Uploads) ──────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Stripe (Payments) ───────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Nodemailer (Email Notifications) ────────────────────────────
# Option 1: Gmail App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password   # Generate: Google Account → Security → App Passwords
EMAIL_FROM=LuxeDrive <your@gmail.com>

# Option 2: Mailgun / SendGrid (uncomment and replace)
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USER=postmaster@mg.yourdomain.com
# EMAIL_PASS=your_mailgun_smtp_password

# ── Admin Seed (for initial admin user) ─────────────────────────
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@luxedrive.com
ADMIN_PASSWORD=Admin@123!
