# ────────────────────────────────────────────────────────────
# LuxeDrive Frontend — Production .env
# Copy to .env and fill in real values
# ────────────────────────────────────────────────────────────

# Your deployed backend URL (no trailing slash)
VITE_API_URL=https://your-api.onrender.com/api

# Stripe publishable key (safe to expose on frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# App details
VITE_APP_NAME=LuxeDrive
VITE_APP_ENV=production
