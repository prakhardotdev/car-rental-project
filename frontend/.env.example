# ─────────────────────────────────────────────────────────
# LuxeDrive Frontend — .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Stripe publishable key (from Stripe Dashboard)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay key (alternative to Stripe)
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx

# Google OAuth Client ID (for social login)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxx.apps.googleusercontent.com

# App environment (development | staging | production)
VITE_APP_ENV=development

# App name (shown in browser title)
VITE_APP_NAME=LuxeDrive
